<mvc:View xmlns:rowmodes="sap.ui.table.rowmodes" controllerName="contractmanagement.contractmanagement.controller.Equipment."
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:uxap="sap.uxap" 
    xmlns:f="sap.f"
    xmlns:t="sap.ui.table" 
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <f:DynamicPage 
        showFooter="true" 
        headerExpanded="true" 
        headerPinned="true" >
        <f:title>
            <uxap:ObjectPageDynamicHeaderTitle >
                <uxap:heading>
                    <Title text="{i18n>equipmentAssig}"/>
                </uxap:heading>
                <uxap:navigationActions>
                    <Button press="onNavBack" type="Emphasized" icon="sap-icon://undo" />
                </uxap:navigationActions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </f:title>
            
        <f:content>
            <t:Table 
                id="tblEquipment"
                alternateRowColors="true"
                busyIndicatorDelay="0"
                enableColumnFreeze="true"
                enableSelectAll="true"
                enableColumnReordering="true"
                showNoData="true"
                selectionBehavior="RowSelector"
                rowSelectionChange="onSelectRow"
                rows="{mContractManagement>/arrEquipment}"
                selectionMode="MultiToggle">
                <t:extension>
                    <OverflowToolbar>
                        <Title text="{i18n>equipment}s ({= ${mContractManagement>/arrEquipment}.length })"/>
                        <ToolbarSpacer />
                        <Button text="{i18n>addEquipment}" visible="{= !${mContractManagement>/isEquipmentCup} }" press="onAddEquipment" type="Emphasized" icon="sap-icon://add" />
                        <Button press="onDeleteEquipment" visible="{= !${mContractManagement>/isEquipmentCup} }" type="Reject" icon="sap-icon://delete" />
                    </OverflowToolbar>                        
                </t:extension>
                <t:rowMode>
                    <rowmodes:Auto />
                </t:rowMode>
                <t:columns >
                    <t:Column hAlign="Center" >
                        <Text text="{i18n>equipment}" />
                        <t:template >
                            <Input showValueHelp="true"  valueHelpRequest="onOpenPopUpEquipment" value="{path:'mContractManagement>EquipmentB'}" />
                        </t:template>
                    </t:Column>
                    <t:Column >
                        <Text text="{i18n>Denomination}"/>
                        <t:template >
                            <Text text="{path:'mContractManagement>DescriptionE'}" />
                        </t:template>
                    </t:Column>                       
                    <t:Column >
                        <Text text="{i18n>technicalLocation}"/>
                        <t:template >
                            <Text text="{path:'mContractManagement>Location'}" />
                        </t:template>
                    </t:Column>
                    <t:Column >
                        <Text text="{i18n>denomitaionTechnicalLocation}"/>
                        <t:template >
                            <Text text="{path:'mContractManagement>DescriptionL'}" />
                        </t:template>
                    </t:Column>
                    <t:Column >
                        <Text text="{i18n>installationDate}"/>
                        <t:template >
                            <DatePicker editable="false" dateValue="{mContractManagement>InstalationDate}" />
                        </t:template>
                    </t:Column>
                    <t:Column visible="{mContractManagement>/isEquipmentCup}" >
                        <Text text="{i18n>CUP}"/>
                        <t:template >
                            <Button press="onOpenPopUpCup" type="Accept" text="{mContractManagement>cup}"/>

                            <!-- text="{
                                    parts: ['mContractManagement>cup'], 
                                    formatter: '.formatter.formatAmmount'
                                }" -->

                        </t:template>
                    </t:Column>
                </t:columns>
                <t:noData>
                    <IllustratedMessage
                        illustrationType="sapIllus-SimpleEmptyList"
                        enableVerticalResponsiveness="true"
                        title="{i18n>thereAreNotEntriesYet}"
                        description="{i18n>thereAreNotEntriesYetDesc}"/>
                </t:noData>
            </t:Table>
        </f:content>
        <f:footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button 
                    id="btnNext" 
                    type="Accept" 
                    visible="{= !${mContractManagement>/isEquipmentCup} }"
                    text="{i18n>accept}" 
                    press="onSaveEquipment"
                    icon="sap-icon://cart-approval" />
                <Button 
                    type="Reject" 
                    text="{i18n>cancel}" 
                    icon="sap-icon://clear-filter" 
                    press="onClear" />
			</OverflowToolbar>
        </f:footer>
    
    </f:DynamicPage>

</mvc:View>