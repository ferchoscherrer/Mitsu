<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
    <TableSelectDialog
		noDataText="{i18n>noData}"
		title="{i18n>Material}"
		search=".onSearchMaterial"
		confirm=".onSelectMaterial"
		showClearButton="true"
		items= "{
			path : 'ZSD_CATALOGOS_SRV>/MaterialMasterSet',
			filters: {
				path: 'Mtart',
				operator: 'EQ',
				value1: 'ZSER'
			}
		}"
		contentHeight= "30%"
		contentWidth="30%"
		resizable="true">
		<ColumnListItem>
			<cells>
                <Text text="{ZSD_CATALOGOS_SRV>Material}"/>
                <Text text="{ZSD_CATALOGOS_SRV>Description}"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column minScreenWidth="Tablet" demandPopin="true" width="12em">
				<header>
					<Text text="{i18n>code}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true" width="12em">
				<header>
					<Text text="{i18n>description}" />
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>