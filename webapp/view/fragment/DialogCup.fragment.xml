<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table" 
	xmlns:rowmodes="sap.ui.table.rowmodes"
	>
    <Dialog resizable="true" verticalScrolling="false" draggable="true" contentWidth="50%" contentHeight="28%">
        <customHeader>            
            <Toolbar>
                <Title text="{i18n>cupService}" />
                <ToolbarSpacer />
                <Button icon="sap-icon://decline" type="Default" press="onCloseWorkForce" />
            </Toolbar>
        </customHeader>
        <content>
            <t:Table  
				alternateRowColors="true"
				busyIndicatorDelay="0"
				enableColumnFreeze="true"
				enableSelectAll="true"
				enableColumnReordering="true"
				showNoData="true"
				selectionBehavior="RowSelector"
				rowSelectionChange="onSelectRow"
				rows="{mContractManagement>/arrWorkForce}"
				selectionMode="None">
                <t:layoutData>
                    <FlexItemData growFactor="1" shrinkFactor="1" />
                </t:layoutData>
                <t:rowMode>
                    <rowmodes:Auto />
                </t:rowMode>
                <t:columns>
                    <t:Column>
                        <Label text="Rubro" />
                        <t:template>
                            <Text text="{mContractManagement>item}" />
                        </t:template>
                    </t:Column>

                    <t:Column hAlign="Center">
                        <Label text="Anual" />
                        <t:template>
                            <Text text="{mContractManagement>annual}" />
                        </t:template>
                    </t:Column>

                    <t:Column hAlign="Center">
                        <Label text="Fecha" />
                        <t:template>
                            <DatePicker editable="false" dateValue="{mContractManagement>date}" />
                            <!-- <Text text="{mContractManagement>date}" /> -->
                        </t:template>
                    </t:Column>

                    <t:Column hAlign="Center">
                        <Label text="Mensual" />
                        <t:template>

                        <Input 
    textAlign="Right"
    liveChange=".onValidateNumber"
    submit="_onCalculateTotalWorkForce"
    change="_onCalculateTotalWorkForce"
    editable="{= ${mContractManagement>key} !== '06' }"
    value="{
        path: 'mContractManagement>monthly',
        type: 'sap.ui.model.type.Float',
        formatOptions: {
            minFractionDigits: 2,
            maxFractionDigits: 2,
            groupingEnabled: true,
            groupingSeparator: ',',
            decimalSeparator: '.'
        }
    }" 
/>
                    
                             <!-- 
                            <Input submit="_onCalculateTotalWorkForce" editable="{= ${mContractManagement>key} !== '06'}"
                                value="{mContractManagement>monthly}"
                            />
                            -->
                            <!-- 
                                value="{
                                    parts: ['mContractManagement>monthly'], 
                                    formatter: '.formatter.formatAmmount'
                                }"
                             -->
                        </t:template>
                    </t:Column>
                </t:columns>
            </t:Table>
        </content>

        <beginButton>
            <Button text="Guardar" type="Success" press="onSaveWorkForce" />
        </beginButton>

        <endButton>
            <Button text="Cancelar" type="Reject" press="onCloseWorkForce" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>