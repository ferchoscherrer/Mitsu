<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core">
    <TableSelectDialog
		noDataText="{i18n>noData}"
		title="{i18n>requester}"
		search=".onSearchRequester"
		confirm=".onSelectRequester"
		showClearButton="true"
		items= "{path : 'ZSD_CATALOGOS_SRV>/CustomerSet'}"
		contentHeight= "30%"
		contentWidth="30%"
		resizable="true"
		searchable="false"
		>
		<ColumnListItem>
			<cells>
                <Text text="{ZSD_CATALOGOS_SRV>CustomerCode}"/>
                <Text text="{ZSD_CATALOGOS_SRV>Name1}"/>
			</cells>
		</ColumnListItem>
		<columns>
			<Column minScreenWidth="Tablet" demandPopin="true" width="12em">
				<header>
					<Text text="{i18n>id}" />
				</header>
			</Column>
			<Column minScreenWidth="Tablet" demandPopin="true" width="12em">
				<header>
					<Text text="{i18n>name}" />
				</header>
			</Column>
		</columns>
	</TableSelectDialog>
</core:FragmentDefinition>